{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "TaskFlow Desktop",
  "outputfilename": "taskflow-desktop",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "NeuroStack",
    "email": "admin@neurostack.in"
  },
  "info": {
    "companyName": "NeuroStack",
    "productName": "TaskFlow Desktop",
    "productVersion": "1.0.0",
    "copyright": "Copyright © 2026 NeuroStack",
    "comments": "Lightweight desktop companion for TaskFlow task management"
  },
  "nsisType": "custom",
  "windows": {
    "webviewIsTransparent": false,
    "windowIsTranslucent": false,
    "disableWindowIcon": false,
    "disableFramelessWindowDecorations": false,
    "webviewUserDataPath": "",
    "webviewBrowserPath": "",
    "theme": "SystemDefault"
  }
}
